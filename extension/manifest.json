{
  "manifest_version": 3,
  "name": "VisaKit",
  "version": "1.0.0",
  "description": "Securely save your visa profile and autofill online Indian Visa application forms.",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://indianvisaonline.gov.in/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "VisaKit",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://indianvisaonline.gov.in/*"
      ],
      "js": [
        "src/content/index.js"
      ],
      "run_at": "document_end"
    }
  ]
}
