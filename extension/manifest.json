{
  "manifest_version": 3,
  "name": "VisaKit",
  "version": "1.0",
  "description": "Securely save your visa profile and autofill online Indian Visa application forms.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://indianvisaonline.gov.in/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "VisaKit"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://indianvisaonline.gov.in/*"
      ],
      "js": [
        "src/content/index.js"
      ],
      "run_at": "document_end"
    }
  ]
}
